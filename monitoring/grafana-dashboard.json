{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "style": "dark",
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "title": "STSE | API Ops Control Center",
  "uid": "stse-netflix-ops-v4",
  "version": 1,

  "panels": [

    {
      "type": "row",
      "title": "SYSTEM OVERVIEW",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 1,
      "type": "stat",
      "title": "System Availability",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "targets": [
        { "expr": "100 * sum(external_api_up) / count(external_api_up)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 85 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Healthy Services",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "targets": [{ "expr": "sum(external_api_up)" }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Down Services",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "targets": [{ "expr": "count(external_api_up) - sum(external_api_up)" }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Total Checks",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "targets": [{ "expr": "external_api_check_runs_total" }]
    },

    {
      "type": "row",
      "title": "PERFORMANCE LAYER",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency (P95)",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(external_api_request_duration_ms_bucket[5m])) by (le, api, endpoint))"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Success vs Failure Rate",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "expr": "sum(rate(external_api_successes_total[5m])) / sum(rate(external_api_requests_total[5m])) * 100"
        }
      ]
    },

    {
      "type": "row",
      "title": "SYSTEM HEALTH MATRIX",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }
    },

    {
      "id": 7,
      "type": "table",
      "title": "Endpoint Health Status",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "targets": [
        { "expr": "external_api_up" },
        { "expr": "external_api_last_status_code" },
        { "expr": "time() - external_api_last_success_unix" }
      ]
    },

    {
      "type": "row",
      "title": "TRAFFIC & RELIABILITY",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }
    },

    {
      "id": 8,
      "type": "barchart",
      "title": "Failures by Service",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "sum(increase(external_api_failures_total[1h])) by (api)"
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Request Traffic (RPS)",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "targets": [
        {
          "expr": "sum(rate(external_api_requests_total[1m])) by (api)"
        }
      ]
    },

    {
      "type": "row",
      "title": "OPERATIONAL INSIGHTS",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }
    },

    {
      "id": 10,
      "type": "gauge",
      "title": "GitHub Rate Remaining",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 35 },
      "targets": [{ "expr": "github_rate_remaining{resource=\"core\"}" }]
    },

    {
      "id": 11,
      "type": "stat",
      "title": "Last Status Code",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 35 },
      "targets": [{ "expr": "external_api_last_status_code" }]
    },

    {
      "id": 12,
      "type": "stat",
      "title": "Live Monitoring Pulse",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 35 },
      "targets": [
        { "expr": "rate(external_api_check_runs_total[1m])" }
      ]
    },
    
   
   {
  "id": 13,
  "type": "text",
  "title": "System Intelligence Summary",
  "gridPos": { "h": 10, "w": 24, "x": 0, "y": 44 },
  "options": {
    "mode": "markdown"
  },
  "targets": [
    {
      "url": "http://localhost:4000/summary"
    }
  ]
}

  ]
}